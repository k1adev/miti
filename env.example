# Configurações do Servidor
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Configurações do Banco de Dados
DB_PATH=./database.sqlite

# Configurações de Segurança
SESSION_SECRET=sua_chave_secreta_aqui
CORS_ORIGIN=http://localhost:3000

# Configurações de Log
LOG_LEVEL=info

# Configurações de Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Configurações de API Externa
API_TIMEOUT=30000
API_RETRY_ATTEMPTS=3

# JWT Secret
JWT_SECRET=apoli-secret-key-change-in-production

# Configurações do Bling API
BLING_CLIENT_ID=seu_client_id_aqui
BLING_CLIENT_SECRET=seu_client_secret_aqui
BLING_REDIRECT_URI=http://localhost:3000/api/bling/callback

# ──────────────────────────────────────────────────────────────────────────────
# Crons automáticos (todos em minutos; 0 desliga o respectivo cron)
# ──────────────────────────────────────────────────────────────────────────────
# Sync leve de PEDIDOS dos marketplaces (ML + Shopee). Usa modo delta — só
# pedidos novos/atualizados desde o último sync. Dispara recálculo de custos
# em background para cada pedido modificado, mantendo o relatório de Custos
# de Pedido sempre atualizado.
ORDERS_AUTO_INTERVAL_MIN=5

# Sync de CATÁLOGO (itens/anúncios) — só roda para contas com
# auto_sync_enabled=1. Default desligado.
AUTO_SYNC_INTERVAL_MIN=0

# Pipeline completo de EMISSÃO de NF (send-to-bling + poll + upload Shopee).
# Só roda para contas com auto_invoice_enabled=1 e bling_account_id configurado.
# Default desligado — ligar com cuidado porque emite NF de verdade.
MARKETPLACE_AUTO_INTERVAL_MIN=0

# LEITURA de NFes (fetch-ml-invoices + batch-nfe-check no Bling + poll/upload).
# Sempre on por padrão (10 min). Não emite nada, só consome APIs externas.
NFE_AUTO_INTERVAL_MIN=10
NFE_AUTO_WINDOW_DAYS=30
